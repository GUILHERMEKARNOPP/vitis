rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Qualquer pessoa pode ver a base de vinhos cadastrada
    match /wines/{wineId} {
      allow read: if true;
      allow write: if false; // Cadastro de vinhos apenas por admin via console
    }
    
    // Regras de usuário: leitura/escrita restrita ao próprio usuário
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Coleção interna da Adega do usuário
      match /cellar/{wineId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Coleção interna do Carrinho de compras do usuário
      match /cart/{wineId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Coleção pública de avaliações: qualquer um lê, mas só quem criou pode alterar
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Pedidos de compra (Orders): apenas o dono do pedido pode ler/criar
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
